rules_version = '2';

// TopRatedVAs.com — Firestore security rules
// PHASE 4 (auth): each user can read/write ONLY their own users/{uid} doc,
// which holds { role, name, email, sessionId }. Everything else is denied.
// PHASE 5 will extend this with vaProfiles, unlocks, credits, surveys, reviews,
// and the CRITICAL protected contact subcollection (unreadable before unlock).

service cloud.firestore {
  match /databases/{database}/documents {

    // A user's own account/role document.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // Default deny everything else (Phase 5 opens up specific paths).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
